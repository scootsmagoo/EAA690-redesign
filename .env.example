# Database (Better Auth)
# - Local dev: omit DATABASE_URL to use SQLite at ./eaa-auth.db (no Postgres required)
# - Or set SQLite explicitly: DATABASE_URL=./eaa-auth.db
# - Production / hosted: use PostgreSQL (copy exact string from Neon / Supabase / Vercel Postgres dashboard)
# DATABASE_URL=postgresql://user:password@host:5432/database_name
# Vercel Postgres often injects POSTGRES_URL — the app also reads that if DATABASE_URL is unset.
# If you see "Tenant or user not found" from Postgres: wrong/expired URL, pooler host, or
# Supabase username must be postgres.<project-ref> — copy a fresh connection string from the provider.

# Auth security (optional)
# Comma-separated emails that may skip 2FA at sign-in in dev / non-production only (never on Vercel production).
# AUTH_RELAX_2FA_EMAILS=falonya@gmail.com
# Set AUTH_RELAX_2FA=true on preview/staging if you need the same bypass when NODE_ENV=production.
# Force MFA enrollment redirect locally: NEXT_PUBLIC_AUTH_ENFORCE_MFA=true

# BetterAuth (secret must be at least 32 characters — use a real value, not a short placeholder)
# Generate: openssl rand -base64 32   OR   npx @better-auth/cli secret
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output-at-least-32-chars
# Server + client: canonical origin Better Auth uses for cookies/session (must match the URL in the browser)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Vercel: set both to your live URL, e.g. https://your-app.vercel.app (or your custom domain). If unset, VERCEL_URL is used, which can mismatch a custom domain.
# If you browse via a LAN IP (http://192.168.x.x:3000) and sign-in fails, either open http://localhost:3000 instead, or add:
# BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.x.x:3000

# Sanity CMS (public — safe to commit; required for /studio and content queries)
NEXT_PUBLIC_SANITY_PROJECT_ID=itqpjbjj
NEXT_PUBLIC_SANITY_DATASET=production

# Contact form email (Resend — https://resend.com)
RESEND_API_KEY=
# Where contact form notifications are delivered (comma-separated for multiple inboxes).
CONTACT_EMAIL_TO=info@eaa690.org
#
# --- Production (recommended): verify YOUR domain in Resend → Domains, then: ---
# CONTACT_EMAIL_FROM=EAA 690 <contact@yourdomain.org>
#
# --- Staging workaround: no verified domain yet (e.g. site on *.vercel.app only) ---
# Resend does not allow *.vercel.app as a sending domain. Until you add DNS for a domain you own,
# use their shared test sender and point deliveries at an inbox Resend will accept (often your
# Resend account email — check current limits in Resend docs for onboarding@resend.dev).
# CONTACT_EMAIL_FROM=onboarding@resend.dev
# CONTACT_EMAIL_TO=your-email@example.com
#
# Display name with the test sender (optional):
# CONTACT_EMAIL_FROM=EAA 690 <onboarding@resend.dev>
CONTACT_EMAIL_FROM=

# Optional: dedicated sender for transactional auth mail (password reset, etc).
# Falls back to CONTACT_EMAIL_FROM when unset. Use this when you want auth mail to come
# from a noreply@ address rather than the chapter inbox.
# AUTH_EMAIL_FROM=EAA 690 <noreply@yourdomain.org>

# Form-submission alerts (SMS — optional, scaffolded)
# When all three TWILIO_* vars are set, every program form submission also texts each
# phone number listed in Site Settings → Form notifications → SMS recipients. Until then,
# any numbers configured in the admin UI are saved but no SMS is sent (no error).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=+14045551234

# Mailchimp (newsletter / mailing list — mailchimp.com → Account → Extras → API Keys)
# API key format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1  (the suffix is your datacenter)
MAILCHIMP_API_KEY=
# Audience (list) ID: Mailchimp → Audience → Manage Audience → Settings → Audience name and defaults
MAILCHIMP_LIST_ID=

# Stripe (get keys from dashboard.stripe.com → Developers → API Keys)
# Use test keys (pk_test_ / sk_test_) during development; swap for live keys before launch.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/stripe/webhook` to get this
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create Products in the Dashboard, then paste the Price IDs here.
# Optional if each membership product in Sanity (slug student-membership / individual-membership /
# family-membership) has stripePriceId or unitAmountCents; env vars override catalog when set.
STRIPE_PRICE_STUDENT_MEMBERSHIP=price_...
STRIPE_PRICE_INDIVIDUAL_MEMBERSHIP=price_...
STRIPE_PRICE_FAMILY_MEMBERSHIP=price_...
