# Database (Better Auth)
# - Local dev: omit DATABASE_URL to use SQLite at ./eaa-auth.db (no Postgres required)
# - Or set SQLite explicitly: DATABASE_URL=./eaa-auth.db
# - Production / hosted: use PostgreSQL (copy exact string from Neon / Supabase / Vercel Postgres dashboard)
# DATABASE_URL=postgresql://user:password@host:5432/database_name
# Vercel Postgres often injects POSTGRES_URL — the app also reads that if DATABASE_URL is unset.
# If you see "Tenant or user not found" from Postgres: wrong/expired URL, pooler host, or
# Supabase username must be postgres.<project-ref> — copy a fresh connection string from the provider.

# BetterAuth (secret must be at least 32 characters — use a real value, not a short placeholder)
# Generate: openssl rand -base64 32   OR   npx @better-auth/cli secret
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output-at-least-32-chars
# Server + client: canonical origin Better Auth uses for cookies/session (must match the URL in the browser)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Vercel: set both to your live URL, e.g. https://your-app.vercel.app (or your custom domain). If unset, VERCEL_URL is used, which can mismatch a custom domain.
# If you browse via a LAN IP (http://192.168.x.x:3000) and sign-in fails, either open http://localhost:3000 instead, or add:
# BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.x.x:3000

# Sanity CMS (public — safe to commit; required for /studio and content queries)
NEXT_PUBLIC_SANITY_PROJECT_ID=itqpjbjj
NEXT_PUBLIC_SANITY_DATASET=production

# Stripe (get keys from dashboard.stripe.com → Developers → API Keys)
# Use test keys (pk_test_ / sk_test_) during development; swap for live keys before launch.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/stripe/webhook` to get this
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create Products in the Dashboard, then paste the Price IDs here.
# Optional if each membership product in Sanity (slug student-membership / individual-membership /
# family-membership) has stripePriceId or unitAmountCents; env vars override catalog when set.
STRIPE_PRICE_STUDENT_MEMBERSHIP=price_...
STRIPE_PRICE_INDIVIDUAL_MEMBERSHIP=price_...
STRIPE_PRICE_FAMILY_MEMBERSHIP=price_...
